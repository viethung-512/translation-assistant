{
  "identifier": "default",
  "description": "Default app capabilities",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:default",
    "core:window:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "x-apple.systempreferences:*"
        },
        {
          "url": "app-settings:*"
        }
      ]
    }
  ]
}